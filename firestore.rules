rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function adminPath(uid) {
      return /databases/$(database)/documents/adminUsers/$(uid);
    }

    function isAdmin() {
      return signedIn()
        && exists(adminPath(request.auth.uid))
        && get(adminPath(request.auth.uid)).data.active == true;
    }

    function hasOnlyAllowedKeys(allowedKeys) {
      return request.resource.data.keys().hasOnly(allowedKeys);
    }

    function hasRequiredKeys(requiredKeys) {
      return request.resource.data.keys().hasAll(requiredKeys);
    }

    function validAdminUser() {
      return hasOnlyAllowedKeys(['active', 'email', 'role', 'displayName', 'createdAt', 'updatedAt'])
        && hasRequiredKeys(['active', 'email', 'role'])
        && request.resource.data.active is bool
        && request.resource.data.email is string
        && request.resource.data.role is string;
    }

    function validProduct() {
      return hasOnlyAllowedKeys([
          'category',
          'createdAt',
          'info',
          'info1',
          'info2',
          'inStock',
          'isActive',
          'isHighlighted',
          'photos',
          'priceOptions',
          'published',
          'shipping',
          'slug',
          'sortOrder',
          'title',
          'updatedAt'
        ])
        && hasRequiredKeys(['inStock', 'isActive', 'photos', 'priceOptions', 'published', 'shipping', 'title'])
        && request.resource.data.published is bool
        && request.resource.data.inStock is bool
        && request.resource.data.isActive is bool
        && request.resource.data.photos is list
        && request.resource.data.priceOptions is list
        && request.resource.data.shipping is string
        && request.resource.data.title is string;
    }

    function validEvent() {
      return hasOnlyAllowedKeys([
          'capacity',
          'category',
          'childTicket',
          'createdAt',
          'date',
          'dietaryOptions',
          'eventDates',
          'eventType',
          'info',
          'inStock',
          'isActive',
          'link',
          'photos',
          'priceOptions',
          'published',
          'shipping',
          'slug',
          'sortOrder',
          'title',
          'updatedAt'
        ])
        && hasRequiredKeys(['category', 'date', 'eventDates', 'info', 'inStock', 'isActive', 'photos', 'priceOptions', 'published', 'shipping', 'title'])
        && request.resource.data.eventDates is list
        && request.resource.data.category is string
        && request.resource.data.date is timestamp
        && request.resource.data.info is list
        && request.resource.data.inStock is bool
        && request.resource.data.isActive is bool
        && request.resource.data.photos is list
        && request.resource.data.priceOptions is list
        && request.resource.data.published is bool
        && request.resource.data.shipping is string
        && request.resource.data.title is string;
    }

    function validSiteContent() {
      return hasOnlyAllowedKeys(['createdAt', 'published', 'sections', 'sortOrder', 'updatedAt'])
        && hasRequiredKeys(['published', 'sections'])
        && request.resource.data.published is bool
        && (request.resource.data.sections is map || request.resource.data.sections is list);
    }

    function validInventory() {
      return hasOnlyAllowedKeys(['createdAt', 'dietaryVariant', 'eventDate', 'linkedId', 'linkedType', 'notes', 'stock', 'updatedAt'])
        && hasRequiredKeys(['linkedId', 'linkedType', 'stock'])
        && request.resource.data.linkedId is string
        && request.resource.data.linkedType is string
        && request.resource.data.stock is number;
    }

    match /adminUsers/{userId} {
      allow get: if (signedIn() && request.auth.uid == userId) || isAdmin();
      allow list: if isAdmin();
      allow create, update: if isAdmin() && validAdminUser();
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow get, list: if isAdmin();
      allow create, update: if isAdmin() && validProduct();
      allow delete: if isAdmin();
    }

    match /events/{eventId} {
      allow get, list: if isAdmin();
      allow create, update: if isAdmin() && validEvent();
      allow delete: if isAdmin();
    }

    match /siteContent/{contentId} {
      allow get, list: if isAdmin();
      allow create, update: if isAdmin() && validSiteContent();
      allow delete: if isAdmin();
    }

    match /inventory/{inventoryId} {
      allow get, list: if isAdmin();
      allow create, update: if isAdmin() && validInventory();
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
